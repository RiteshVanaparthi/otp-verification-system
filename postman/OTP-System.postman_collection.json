{
  "info": {
    "name": "OTP System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for OTP verification system"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "contact",
      "value": "test@example.com"
    },
    {
      "key": "otp",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Generate OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('OTP is returned', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson.data).to.have.property('otp');",
              "  pm.collectionVariables.set('otp', responseBodyJson.data.otp);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contact\": \"{{contact}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/generate-otp"
      }
    },
    {
      "name": "Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Token is returned', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson).to.have.property('token');",
              "  pm.collectionVariables.set('token', responseBodyJson.token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contact\": \"{{contact}}\",\n  \"otp\": \"{{otp}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/verify-otp"
      }
    },
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('User id is returned', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  const id = responseBodyJson.data._id || responseBodyJson.data.id;",
              "  pm.expect(id).to.exist;",
              "  pm.collectionVariables.set('userId', id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo User\",\n  \"contact\": \"demo.user@example.com\",\n  \"contactType\": \"email\"\n}"
        },
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Get User By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/{{userId}}"
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated User\"\n}"
        },
        "url": "{{baseUrl}}/api/users/{{userId}}"
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/{{userId}}"
      }
    }
  ]
}
